apiVersion: apps/v1
kind: Deployment
metadata:
  name: chiara-app
spec:
  replicas: {{ .Values.replicaCount }}
  selector:
    matchLabels:
      app: chiara-app
  template:
    metadata:
      labels:
        app: chiara-app
    spec:
      imagePullSecrets:
        {{- toYaml .Values.imagePullSecrets | nindent 8 }}
      containers:
        - name: chiara-app
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag }}"
          ports:
            - containerPort: 80